rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    match /product_images/{imageId} {
      allow read: if true;
      allow write: if true;
    }

    match /contact_inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
